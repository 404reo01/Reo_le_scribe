# Backend
PORT=3000
NODE_ENV=development
# Dev: http://localhost:5173 — Prod: https://your-app.netlify.app
FRONTEND_URL=http://localhost:5173

# Database
POSTGRES_HOST=postgres        # use 127.0.0.1 in prod (network_mode: host)
POSTGRES_PORT=5432
POSTGRES_USER=reo_user
POSTGRES_PASSWORD=reo_pass
POSTGRES_DB=reo_db

# Mediasoup
MEDIASOUP_LISTEN_IP=0.0.0.0
# Dev: 127.0.0.1 — Prod: public IP of the VPS
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_RTP_MIN_PORT=40000
MEDIASOUP_RTP_MAX_PORT=40099
MEDIASOUP_NUM_WORKERS=1

# OpenRouter (summarization) — openrouter.ai
OPENROUTER_API_KEY=your_key_here

# Groq (Whisper STT) — console.groq.com (free tier available)
GROQ_API_KEY=your_key_here
